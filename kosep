### 📊 **Contoh Struktur Data**
```python
session = {"kandang": "A", "umur_mg": 6, "data_timbang": []}

def input_berat(session, berat):
    id_ayam = len(session["data_timbang"]) + 1
    session["data_timbang"].insert(0, {"id_ayam": id_ayam, "berat": berat})
    return session

def analisa(session):
    subset = [d["berat"] for d in session["data_timbang"]]
    mean = sum(subset)/len(subset)
    std_dev = (sum((x-mean)**2 for x in subset)/len(subset))**0.5
    cv = (std_dev/mean)*100
    batas_bawah, batas_atas = mean*0.9, mean*1.1
    uniform_count = sum(1 for x in subset if batas_bawah <= x <= batas_atas)
    uniformity = (uniform_count/len(subset))*100
    return {"mean":mean, "cv":cv, "uniformity":uniformity}
```

